<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox xmlns="http://javafx.com/javafx/23.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="de.handwerkersystem.dlg.ressourceverwalter.RessourceLoeschenScreenController"
    prefHeight="400.0" prefWidth="600.0"
    alignment="TOP_CENTER" spacing="20.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <children>

        <Label text="Ressource Löschen" textAlignment="CENTER">
            <font>
                <Font size="24.0" />
            </font>
        </Label>


        <TableView fx:id="tv_ressource" prefHeight="250.0" prefWidth="560.0">
            <columns>
                <TableColumn fx:id="tc_id" prefWidth="150.0" text="ID" />
                <TableColumn fx:id="tc_art" prefWidth="150.0" text="Art" />
                <TableColumn fx:id="tc_name" prefWidth="260.0" text="Name" />
            </columns>
        </TableView>


        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" text="Zurück"
                    onAction="#bt_zurueckClicked" />
                <Button fx:id="bt_ressourceloeschen" mnemonicParsing="false" text="Ressource löschen"
                    onAction="#bt_ressourceloeschenClicked" />

            </children>
        </HBox>
    </children>
</VBox>