<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/23.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="de.handwerkersystem.dlg.ressourceverwalter.RessourceAnlegenScreenController"
    alignment="TOP_CENTER" spacing="20"
    prefWidth="500" prefHeight="350">


    <children>

        <Label text="Ressource Anlegen">
            <font>
                <Font size="24" />
            </font>
        </Label>

        <HBox spacing="10">
            <children>
                <Label text="Art:" />
                <ComboBox fx:id="cb_art" prefWidth="200" />
            </children>
        </HBox>

        <HBox spacing="10">
            <children>
                <Label text="Name:" />
                <TextField fx:id="tf_name" prefWidth="200" />
            </children>
        </HBox>

        <HBox spacing="10">
            <children>
                <Label text="Kostensatz (€ / h):" />
                <TextField fx:id="tf_kostensatz" prefWidth="150" />
            </children>
        </HBox>

        <HBox alignment="CENTER" spacing="15">
            <children>
                <Button text="Zurück" onAction="#bt_zurueckClicked" />
                <Button text="Speichern" onAction="#bt_speichernClicked" />

            </children>
        </HBox>

    </children>

</VBox>