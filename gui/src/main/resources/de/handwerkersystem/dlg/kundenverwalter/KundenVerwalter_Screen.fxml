<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/11.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="de.handwerkersystem.dlg.kundenverwalter.KundenVerwalterScreenController">

    <children>
        <Label text="Kunden verwalten">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

         
        <Button text="Kunden Anlegen"
                prefHeight="35.0" prefWidth="200.0"
                onAction="#bt_kundenanlegenClicked"/>
                
        <Button text="Kundne Löschen"
                prefHeight="35.0" prefWidth="200.0"
               onAction="#bt_kundenloeschenClicked"/>
               
        <Button text="Kundendaten Ändern"
                prefHeight="35.0" prefWidth="200.0"
                onAction="#bt_kundenaendernClicked"/>
                    <Button text="Kundenliste Anzeigen"
                prefHeight="35.0" prefWidth="200.0"
                onAction="#bt_kundenlisteClicked"/>


        <Button text="Zurück zum Hauptmenü"
                prefHeight="35.0" prefWidth="200.0"
              onAction="#bt_zurueckClicked"  />
    </children>

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>
</VBox>
