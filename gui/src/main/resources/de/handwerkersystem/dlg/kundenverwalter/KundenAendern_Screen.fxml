<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/23.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="de.handwerkersystem.dlg.kundenverwalter.KundenAendernScreenController"
    prefHeight="500.0" prefWidth="700.0"
    alignment="TOP_CENTER" spacing="20.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <children>


        <Label text="Kundendaten ändern">
            <font>
                <Font size="24.0" />
            </font>
        </Label>


        <TableView fx:id="tv_kunden" prefHeight="200.0" prefWidth="400.0">
            <columns>
                <TableColumn fx:id="tc_kundenNr" prefWidth="150.0" text="Kundennummer" />
                <TableColumn fx:id="tc_vorname" prefWidth="200.0" text="Vorname" />
                <TableColumn fx:id="tc_nachname" prefWidth="310.0" text="Nachname" />
            </columns>
        </TableView>


        <GridPane hgap="10.0" vgap="10.0">
         

            <children>
                

                <Label text="Vorname:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="tf_vorname" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Nachname:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="tf_nachname" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="Straße:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="tf_strasse" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                <Label text="HausNr.:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <TextField fx:id="tf_hausNr" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                <Label text="PLZ:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                <TextField fx:id="tf_plz" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                <Label text="Ort:" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                <TextField fx:id="tf_ort" GridPane.rowIndex="6" GridPane.columnIndex="1" />
            </children>
        </GridPane>


        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Button fx:id="bt_zurueck" text="Zurück" onAction="#bt_zurueckClicked" />
                <Button fx:id="bt_speichern" text="Änderungen speichern"
                    onAction="#bt_aenderungspeichernClicked" />

            </children>
        </HBox>

    </children>
</VBox>