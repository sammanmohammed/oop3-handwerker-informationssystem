<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/11.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="de.handwerkersystem.dlg.kundenverwalter.KundenAnlegenScreenController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <children>

        <Label text="Kunden anlegen">
            <font><Font size="24" /></font>
        </Label>

     
        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <children>
                <Label text="Vorname:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="tf_vorname" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Nachname:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="tf_nachname" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Straße:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="tf_strasse" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Hausnummer:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="tf_hausNr" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                <Label text="PLZ:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <TextField fx:id="tf_plz" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                <Label text="Ort:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                <TextField fx:id="tf_ort" GridPane.rowIndex="5" GridPane.columnIndex="1" />
            </children>
        </GridPane>

     
        <HBox alignment="CENTER" spacing="20">
            <Button text="Zurück"
                    prefWidth="200"
                    onAction="#bt_zurueckClicked" />

            <Button text="Speichern"
                    prefWidth="200"
                    onAction="#bt_speichernClicked" />
        </HBox>

    </children>

</VBox>
