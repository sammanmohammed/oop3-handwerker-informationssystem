<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/23.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="de.handwerkersystem.dlg.auftragverwalter.AuftragsbearbeitungScreenController"
    alignment="TOP_CENTER"
    spacing="15.0"
    prefWidth="900.0"
    prefHeight="600.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <children>


        <Label text="Auftragsbearbeitung">
            <font>
                <Font size="24.0" />
            </font>
        </Label>


        <HBox spacing="20.0">
            <children>


                <VBox spacing="5.0">
                    <children>
                        <Label text="Aufträge" />
                        <TableView fx:id="tv_auftraege" prefWidth="380.0" prefHeight="300.0">
                            <columns>

                                <TableColumn fx:id="tc_auftragsNr" text="Nr" prefWidth="80.0" />
                                <TableColumn fx:id="tc_kunde" text="Kunde" prefWidth="200.0" />
                                <TableColumn fx:id="tc_datum" text="Datum" prefWidth="100.0" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>


                <VBox spacing="5.0">
                    <children>
                        <Label text="Ressourceneinsätze zum Auftrag" />
                        <TableView fx:id="tv_zuordnungen" prefWidth="380.0" prefHeight="300.0">
                            <columns>

                                <TableColumn fx:id="tc_ressource" text="Ressource" prefWidth="160.0" />
                                <TableColumn fx:id="tc_stunden" text="Stunden" prefWidth="80.0" />
                                <TableColumn fx:id="tc_satz" text="Stundensatz" prefWidth="100.0" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </HBox>


        <GridPane hgap="10.0" vgap="10.0" alignment="CENTER">
            <padding>
                <Insets top="10.0" left="30.0" right="30.0" bottom="10.0" />
            </padding>
            <children>
                <Label text="Ressource:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <ComboBox fx:id="cb_ressource" prefWidth="250.0"
                    GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Standard-Stundensatz (€):" GridPane.rowIndex="1"
                    GridPane.columnIndex="0" />
                <TextField fx:id="tf_standardSatz" editable="false"
                    GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Einsatzzeit (Stunden):" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="tf_stunden"
                    GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Sonder-Stundensatz (€):" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="tf_stundensatz"
                    GridPane.rowIndex="3" GridPane.columnIndex="1" />

                <CheckBox fx:id="cb_abgeschlossen"
                    text="Auftrag abgeschlossen"
                    disable="true"
                    GridPane.rowIndex="4" GridPane.columnIndex="0"
                    GridPane.columnSpan="2" />

            </children>
        </GridPane>

        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Button text="Zurück"
                    onAction="#bt_zurueckClicked" />
                <Button text="Ressourceneinsatz speichern"
                    onAction="#bt_zuordnungSpeichernClicked" />
                <Button text="Ressourceneinsatz löschen"
                    onAction="#bt_zuordnungLoeschenClicked" />
                <Button text="Auftrag abschließen"
                    onAction="#bt_auftragSpeichernClicked" />

            </children>
        </HBox>

    </children>

</VBox>