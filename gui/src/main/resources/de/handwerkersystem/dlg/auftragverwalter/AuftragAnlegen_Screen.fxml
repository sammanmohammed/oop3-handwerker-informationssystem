<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/23.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="de.handwerkersystem.dlg.auftragverwalter.AuftragAnlegenScreenController"
    alignment="TOP_CENTER"
    spacing="20"
    prefWidth="600"
    prefHeight="500">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <children>

        <Label text="Kundenauftrag anlegen">
            <font>
                <Font size="24" />
            </font>
        </Label>

        <TableView fx:id="tv_kunden" prefHeight="200.0" prefWidth="560.0">
            <columns>
                <TableColumn fx:id="tc_kundenNr" prefWidth="150.0" text="Kundennummer" />
                <TableColumn fx:id="tc_vorname" prefWidth="200.0" text="Vorname" />
                <TableColumn fx:id="tc_nachname" prefWidth="210.0" text="Nachname" />
            </columns>
        </TableView>

        <Label text="Beschreibung (max. 2000 Zeichen)" />
        <TextArea fx:id="ta_beschreibung"
            prefWidth="560"
            prefHeight="120"
            promptText="Beschreibung des Auftrags eingeben..." />

        <Label text="Baustellenadresse" />

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="30" />
                <ColumnConstraints percentWidth="70" />
            </columnConstraints>

            <children>
                <Label text="Straße:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="tf_strasse" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Hausnr:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="tf_hausnr" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="PLZ:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="tf_plz" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Ort:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="tf_ort" GridPane.rowIndex="3" GridPane.columnIndex="1" />
            </children>
        </GridPane>

        <HBox alignment="CENTER" spacing="15">
            <children>
                <Button text="Zurück" onAction="#bt_zurueckClicked" />
                <Button text="Speichern" onAction="#bt_speichernClicked" />
            </children>
        </HBox>

    </children>
</VBox>